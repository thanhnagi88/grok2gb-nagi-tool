{
  "manifest_version": 3,
  "name": "Grok2FB - Nagi Tool",
  "version": "1.0",
  "description": "Auto-post images and videos from Grok.com to Facebook Profile.",
  "permissions": [
    "storage",
    "tabs",
    "scripting",
    "alarms",
    "notifications",
    "offscreen",
    "unlimitedStorage"
  ],
  "host_permissions": [
    "https://grok.com/*",
    "https://*.grok.com/*",
    "https://x.ai/*",
    "https://*.x.ai/*",
    "https://www.facebook.com/*",
    "https://assets.grok.com/*",
    "https://imagine-public.x.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://grok.com/*", "https://x.ai/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://www.facebook.com/*"],
      "js": ["fb-automator.js"],
      "run_at": "document_idle"
    }
  ]
}
